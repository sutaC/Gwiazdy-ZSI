<% if(spinner) { %>
<div
    class="result"
    hx-get="/scraper/status"
    hx-swap="outerHTML"
    hx-trigger="every 10s"
>
    <small>Skrobanie w trakcie</small>
    <div class="spinner"></div>
</div>
<% } else { %>
<div class="result">
    <% if (results) { %>
    <h3>Skrobanie zakończone</h3>
    <ul>
        <li>Rodzaj skrobania: <%= results.type %></li>
        <li>Czas trwania: <%= (results.timeElapsed / 1000) %>s</li>
        <li>Limit stron: <%= results.limit %></li>
        <li>Znalezione zdjęcia: <%= results.found %></li>
        <li>Dodane nowe zdjęcia: <%= results.added %></li>
        <% if (results?.cachedSkip >= 0) { %>
        <li>Artykuły pominięte przez caching: <%= results.cachedSkip %></li>
        <% } %>
    </ul>
    <% } else { %>
    <h3>Brak zapisu skrobania</h3>
    <% } %>
    <button hx-boost="true" hx-on:click="location.reload()">Odśwież</button>
</div>

<% } %>
